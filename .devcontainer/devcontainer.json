{
  "name": "Linux Devcontainer",
  "build": {
    "dockerfile": "../Dockerfile",
    "args": {
      "USERNAME": "appuser",
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },
  "remoteUser": "appuser",
  "mounts": [
    "source=${localWorkspaceFolder},target=/app,type=bind,consistency=cached"
  ]
}
